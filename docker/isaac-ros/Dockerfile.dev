ARG BASE_IMAGE=phys-ros:isaac-manipulation
FROM ${BASE_IMAGE}

ARG ROS_DISTRO=jazzy
ARG ORBBEC_REF=main
ARG PIPER_SDK_VERSION=0.6.1

LABEL org.opencontainers.image.title="phys-ros:isaac-dev"
LABEL org.opencontainers.image.description="Isaac ROS development environment with Dabai and Piper dependencies"

ENV DEBIAN_FRONTEND=noninteractive
ENV ORBBEC_WS=/opt/orbbec_sdk_v1_ws
ENV PHYS_ROS_WS=/workspaces/phys-ros
ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV PIP_NO_CACHE_DIR=1

SHELL ["/bin/bash", "-c"]

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update \
    && mkdir -p "${ORBBEC_WS}/src" \
    && git clone --depth 1 --branch "${ORBBEC_REF}" --single-branch \
        https://github.com/orbbec/OrbbecSDK_ROS2.git \
        "${ORBBEC_WS}/src/OrbbecSDK_ROS2" \
    && git -C "${ORBBEC_WS}/src/OrbbecSDK_ROS2" rev-parse HEAD \
        > "${ORBBEC_WS}/ORBBEC_COMMIT" \
    && if [[ ! -f /etc/ros/rosdep/sources.list.d/20-default.list ]]; then rosdep init; fi \
    && rosdep update \
    && source "/opt/ros/${ROS_DISTRO}/setup.bash" \
    && rosdep install \
        --from-paths "${ORBBEC_WS}/src/OrbbecSDK_ROS2" \
        --ignore-src -r -y \
    && colcon --log-base "${ORBBEC_WS}/log" build \
        --base-paths "${ORBBEC_WS}/src/OrbbecSDK_ROS2" \
        --build-base "${ORBBEC_WS}/build" \
        --install-base "${ORBBEC_WS}/install" \
        --packages-up-to orbbec_camera \
        --event-handlers console_direct+ \
    && rm -rf "${ORBBEC_WS}/src" "${ORBBEC_WS}/build" "${ORBBEC_WS}/log"

RUN python3 -m pip install "piper-sdk==${PIPER_SDK_VERSION}"

RUN usermod -aG dialout admin \
    && mkdir -p "${PHYS_ROS_WS}" \
    && echo "source ${ORBBEC_WS}/install/setup.bash" \
        > /etc/profile.d/phys-ros-dev.sh \
    && echo "source ${ORBBEC_WS}/install/setup.bash" >> /etc/bash.bashrc \
    && echo "[ -f ${PHYS_ROS_WS}/install/setup.bash ] && source ${PHYS_ROS_WS}/install/setup.bash" \
        >> /etc/bash.bashrc

WORKDIR ${PHYS_ROS_WS}
